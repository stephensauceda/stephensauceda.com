{
  "alias": "stephensauceda.com",
  "version": 2,
  "builds": [
    {
      "src": "next.config.js",
      "use": "@now/next"
    }
  ],
  "env": {
    "API_ENDPOINT": "@api_endpoint",
    "ACCESS_TOKEN": "@access_token"
  },
  "build": {
    "env": {
      "API_ENDPOINT": "@api_endpoint",
      "ACCESS_TOKEN": "@access_token"
    }
  },
  "routes": [
    {
      "src": "/notes.*",
      "continue": true,
      "headers": {
        "cache-control": "s-maxage=3600, max-age=0"
      }
    },
    {
      "src": "/",
      "continue": true,
      "headers": {
        "cache-control": "s-maxage=2592000, max-age=0"
      }
    }
  ]
}
